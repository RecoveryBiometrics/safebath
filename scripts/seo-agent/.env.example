# Google Search Console API credentials
# See SETUP.md for step-by-step instructions to get these values.
# Copy this file to .env and fill in the values. Never commit .env to git.

# Paste the entire JSON contents of your service account key file as a single line
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"seo-agent@YOUR_PROJECT.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# The exact URL of your Search Console property (must match what's in GSC)
GSC_SITE_URL=https://safebathgrabbar.com/

# Email delivery (Gmail SMTP)
# Create an app password at https://myaccount.google.com/apppasswords
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
